# Base URL of your DSS webapp (Docker) — WITHOUT trailing slash.
# The REST validation endpoint used is:  ${DSS_API_URL}/services/rest/validation/validateSignature
#
# Example for the official Docker image (dssdemo) exposed on port 8080:
DSS_API_URL=http://localhost:8080

# Optional: max upload size in megabytes (default 20)
MAX_UPLOAD_MB=20

# Optional: request timeout to the DSS backend in milliseconds (default 60000)
DSS_TIMEOUT_MS=60000

# Optional: log verbosity — debug | info | warn | error (default info)
# Logs are emitted as one JSON line per event to stdout/stderr.
LOG_LEVEL=info

# Optional: HTTP Basic authentication. Comma-separated list of user:password
# pairs. When set, the WHOLE site (pages + all /api/* endpoints) requires a
# login — browsers show the native login dialog; clients send
# `Authorization: Basic base64(user:password)`. Leave empty to disable auth
# (e.g. local development).
#   Example: BASIC_AUTH_USERS=sample:sample,alice:s3cret
BASIC_AUTH_USERS=

# Optional: comma-separated usernames allowed to read GET /api/stats. Must also
# exist in BASIC_AUTH_USERS. Non-admins receive 403. If empty (with auth on),
# nobody may read stats.
#   Example: ADMIN_USERS=admin
ADMIN_USERS=

# Optional: file for the per-user validation counter used by GET /api/stats.
# Default /data/validations.jsonl (mount a volume there to persist it).
STATS_FILE=/data/validations.jsonl
